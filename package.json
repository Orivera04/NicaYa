{
  "name": "motoya",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @motoya/api dev\" \"pnpm --filter @motoya/web dev\"",
    "dev:api": "pnpm --filter @motoya/api dev",
    "dev:web": "pnpm --filter @motoya/web dev",
    "build": "pnpm --filter @motoya/shared build && pnpm --filter @motoya/api build && pnpm --filter @motoya/web build",
    "test": "pnpm test:api && pnpm test:web",
    "test:api": "pnpm --filter @motoya/api test",
    "test:web": "pnpm --filter @motoya/web test",
    "lint": "pnpm --filter @motoya/api lint && pnpm --filter @motoya/web lint",
    "typecheck": "pnpm --filter @motoya/shared typecheck && pnpm --filter @motoya/api typecheck && pnpm --filter @motoya/web typecheck",
    "db:migrate": "pnpm --filter @motoya/api prisma:migrate",
    "db:seed": "pnpm --filter @motoya/api prisma:seed"
  },
  "devDependencies": {
    "@eslint/js": "9.19.0",
    "concurrently": "^9.1.2",
    "typescript-eslint": "8.22.0"
  }
}
