generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}
enum Role { 
 CLIENT
 RIDER
 ADMIN
}
enum UserStatus { 
 ACTIVE
 SUSPENDED
 DISABLED
}
enum RiderApproval { 
 PENDING
 APPROVED
 REJECTED
}
enum SubscriptionStatus { 
 PENDING
 ACTIVE
 EXPIRED
 CANCELLED
}
enum TripStatus { 
 REQUESTED
 ACCEPTED
 RIDER_ON_THE_WAY
 RIDER_ARRIVED
 IN_PROGRESS
 COMPLETED
 CANCELLED_BY_CLIENT
 CANCELLED_BY_RIDER
 CANCELLED_BY_ADMIN
}
enum OfferStatus {
 PENDING
 ACCEPTED
 REJECTED
 EXPIRED
}
enum PaymentStatus {
 PENDING
 CONFIRMED
 EXPIRED
 CANCELLED
}
enum PaymentMethod {
 POINT_EXPRESS
}
model User {
 id String @id @default(cuid())
 name String
 email String @unique
 passwordHash String
 role Role
 status UserStatus @default(ACTIVE)
 phone String?
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 clientProfile ClientProfile?
 riderProfile RiderProfile?
 refreshTokens RefreshToken[]
 clientTrips Trip[] @relation("ClientTrips")
 riderTrips Trip[] @relation("RiderTrips")
 activatedSubscriptions RiderSubscription[] @relation("ActivatedBy")
 ratingsGiven Rating[] @relation("RatingAuthor")
 ratingsReceived Rating[] @relation("RatingRider")
 auditLogs AuditLog[] @relation("AuditActor")
 savedPlaces SavedPlace[]
 riderOffers TripOffer[]
}
model ClientProfile {
 id String @id @default(cuid())
 userId String @unique
 user User @relation(fields:[userId],references:[id],onDelete:Cascade)
}
model RiderProfile {
 id String @id @default(cuid())
 userId String @unique
 user User @relation(fields:[userId],references:[id],onDelete:Cascade)
 approval RiderApproval @default(PENDING)
 available Boolean @default(false)
 vehiclePlate String?
 vehicleModel String?
 nationalId String?
 driverLicense String?
 documentsVerifiedAt DateTime?
 subscriptions RiderSubscription[]
 subscriptionPayments SubscriptionPayment[]
}
model RiderSubscription {
 id String @id @default(cuid())
 riderId String
 rider RiderProfile @relation(fields:[riderId],references:[id],onDelete:Cascade)
 status SubscriptionStatus @default(PENDING)
 startsAt DateTime?
 expiresAt DateTime?
 pricePaid Decimal? @db.Decimal(10,2)
 currency String @default("USD")
 activatedById String?
 activatedBy User? @relation("ActivatedBy",fields:[activatedById],references:[id])
 createdAt DateTime @default(now())
}
model SubscriptionPayment {
 id String @id @default(cuid())
 riderId String
 rider RiderProfile @relation(fields:[riderId],references:[id],onDelete:Cascade)
 reference String @unique
 amount Decimal @db.Decimal(10,2)
 currency String @default("NIO")
 method PaymentMethod @default(POINT_EXPRESS)
 status PaymentStatus @default(PENDING)
 expiresAt DateTime
 confirmedAt DateTime?
 confirmedById String?
 createdAt DateTime @default(now())
 @@index([riderId,status])
 @@index([status,expiresAt])
}
model Trip {
 id String @id @default(cuid())
 clientId String
 client User @relation("ClientTrips",fields:[clientId],references:[id])
 riderId String?
 rider User? @relation("RiderTrips",fields:[riderId],references:[id])
 status TripStatus @default(REQUESTED)
 originLat Float
 originLng Float
 originAddress String
 destinationLat Float
 destinationLng Float
 destinationAddress String
 distanceKm Float
 estimatedPrice Decimal @db.Decimal(10,2)
 proposedPrice Decimal? @db.Decimal(10,2)
 finalPrice Decimal? @db.Decimal(10,2)
 estimatedDurationMin Int
 serviceCode String @default("MOTO")
 expiresAt DateTime?
 currency String @default("USD")
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 histories TripStatusHistory[]
 rating Rating?
 offers TripOffer[]
}
model TripOffer {
 id String @id @default(cuid())
 tripId String
 trip Trip @relation(fields:[tripId],references:[id],onDelete:Cascade)
 riderId String
 rider User @relation(fields:[riderId],references:[id],onDelete:Cascade)
 amount Decimal @db.Decimal(10,2)
 currency String @default("NIO")
 status OfferStatus @default(PENDING)
 expiresAt DateTime
 createdAt DateTime @default(now())
 @@index([tripId,status])
 @@index([riderId,status])
}
model TripStatusHistory {
 id String @id @default(cuid())
 tripId String
 trip Trip @relation(fields:[tripId],references:[id],onDelete:Cascade)
 status TripStatus
 actorId String?
 createdAt DateTime @default(now())
 @@index([tripId,createdAt])
}
model Rating {
 id String @id @default(cuid())
 tripId String @unique
 trip Trip @relation(fields:[tripId],references:[id],onDelete:Cascade)
 authorId String
 author User @relation("RatingAuthor",fields:[authorId],references:[id])
 riderId String
 rider User @relation("RatingRider",fields:[riderId],references:[id])
 score Int
 comment String?
 createdAt DateTime @default(now())
}
model AuditLog {
 id String @id @default(cuid())
 actorId String?
 actor User? @relation("AuditActor",fields:[actorId],references:[id])
 action String
 entity String
 entityId String?
 metadata Json?
 createdAt DateTime @default(now())
 @@index([entity,entityId])
}
model RefreshToken {
 id String @id @default(cuid())
 tokenHash String @unique
 userId String
 user User @relation(fields:[userId],references:[id],onDelete:Cascade)
 expiresAt DateTime
 revokedAt DateTime?
 createdAt DateTime @default(now())
}
model SystemSetting {
 key String @id
 value String
 updatedAt DateTime @updatedAt
}
model SavedPlace {
 id String @id @default(cuid())
 userId String
 user User @relation(fields:[userId],references:[id],onDelete:Cascade)
 label String
 address String
 reference String?
 lat Float
 lng Float
 createdAt DateTime @default(now())
 @@unique([userId,label])
}
model Advertisement {
 id String @id @default(cuid())
 title String
 description String?
 imageUrl String?
 actionLabel String?
 actionUrl String?
 backgroundColor String @default("#f97316")
 textColor String @default("#ffffff")
 displayOrder Int @default(0)
 active Boolean @default(true)
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 @@index([active,displayOrder])
}
