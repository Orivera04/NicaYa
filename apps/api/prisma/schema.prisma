generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}
enum Role { 
 CLIENT
 RIDER
 ADMIN
}
enum UserStatus { 
 ACTIVE
 SUSPENDED
 DISABLED
}
enum RiderApproval { 
 PENDING
 APPROVED
 REJECTED
}
enum ClientActivationStatus {
 REGISTERED
 SEMI_ACTIVE
 VERIFICATION_PENDING
 ACTIVE
 REQUIRES_CORRECTION
 SUSPENDED
 REJECTED
 DEACTIVATED
}
enum RiderOnboardingStatus {
 REGISTERED
 PROFILE_INCOMPLETE
 DOCUMENTS_PENDING
 UNDER_REVIEW
 REQUIRES_CORRECTION
 REJECTED
 APPROVED
 SUBSCRIPTION_REQUIRED
 READY_TO_WORK
}
enum RiderDocumentType {
 NATIONAL_ID
 DRIVER_LICENSE
 VEHICLE_REGISTRATION
 INSURANCE
}
enum RiderDocumentStatus {
 NOT_SUBMITTED
 SUBMITTED
 UNDER_REVIEW
 APPROVED
 REJECTED
 REQUIRES_CORRECTION
 EXPIRED
 EXPIRING_SOON
}
enum SubscriptionStatus { 
 PENDING
 ACTIVE
 EXPIRED
 CANCELLED
}
enum TripStatus { 
 REQUESTED
 ACCEPTED
 RIDER_ON_THE_WAY
 RIDER_ARRIVED
 IN_PROGRESS
 COMPLETED
 CANCELLED_BY_CLIENT
 CANCELLED_BY_RIDER
 CANCELLED_BY_ADMIN
}
enum OfferStatus {
 PENDING
 ACCEPTED
 REJECTED
 EXPIRED
}
enum PaymentStatus {
 PENDING
 CONFIRMED
 EXPIRED
 CANCELLED
}
enum PaymentMethod {
 POINT_EXPRESS
}
enum SubscriptionOrderStatus {
 CREATED
 PENDING_PAYMENT
 PENDING_REVIEW
 COMPLETED
 EXPIRED
 CANCELLED
}
enum SubscriptionPaymentStatus {
 PENDING_PAYMENT
 PENDING_REVIEW
 APPROVED
 REJECTED
 EXPIRED
 CANCELLED
}
enum SubscriptionPaymentMethodCode {
 MOTO_EXPRESS
 BANK_TRANSFER
}
model User {
 id String @id @default(cuid())
 name String
 email String @unique
 passwordHash String
 role Role
 status UserStatus @default(ACTIVE)
 phone String?
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 clientProfile ClientProfile?
 riderProfile RiderProfile?
 refreshTokens RefreshToken[]
 clientTrips Trip[] @relation("ClientTrips")
 riderTrips Trip[] @relation("RiderTrips")
 activatedSubscriptions RiderSubscription[] @relation("ActivatedBy")
 ratingsGiven Rating[] @relation("RatingAuthor")
 ratingsReceived Rating[] @relation("RatingRider")
 auditLogs AuditLog[] @relation("AuditActor")
 savedPlaces SavedPlace[]
 riderOffers TripOffer[]
}
model ClientProfile {
 id String @id @default(cuid())
 userId String @unique
 user User @relation(fields:[userId],references:[id],onDelete:Cascade)
 activationStatus ClientActivationStatus @default(ACTIVE)
 phoneVerifiedAt DateTime?
 identityVerifiedAt DateTime?
 verificationNote String?
}
model RiderProfile {
 id String @id @default(cuid())
 userId String @unique
 user User @relation(fields:[userId],references:[id],onDelete:Cascade)
 approval RiderApproval @default(PENDING)
 available Boolean @default(false)
 vehiclePlate String?
 vehicleModel String?
 insuranceExpiresAt DateTime?
 nationalId String?
 driverLicense String?
 documentsVerifiedAt DateTime?
 onboardingStatus RiderOnboardingStatus @default(PROFILE_INCOMPLETE)
 workZoneConfigured Boolean @default(false)
 workZoneDepartment String?
 workZoneLat Float?
 workZoneLng Float?
 workZoneUpdatedAt DateTime?
 documentsSubmittedAt DateTime?
 onboardingNote String?
 documents RiderDocument[]
 workZoneHistory WorkZoneHistory[]
 subscriptions RiderSubscription[]
 subscriptionPayments SubscriptionPayment[]
 subscriptionOrders SubscriptionOrder[]
}
model WorkZoneHistory {
 id String @id @default(cuid())
 riderId String
 rider RiderProfile @relation(fields:[riderId],references:[id],onDelete:Cascade)
 department String
 lat Float
 lng Float
 reason String
 createdAt DateTime @default(now())
 @@index([riderId,createdAt])
}
model RiderDocument {
 id String @id @default(cuid())
 riderId String
 rider RiderProfile @relation(fields:[riderId],references:[id],onDelete:Cascade)
 type RiderDocumentType
 status RiderDocumentStatus @default(NOT_SUBMITTED)
 reference String?
 frontImage String?
 backImage String?
 expiresAt DateTime?
 reviewedAt DateTime?
 reviewedById String?
 rejectionReason String?
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 @@unique([riderId,type])
 @@index([status,expiresAt])
}
model RiderSubscription {
 id String @id @default(cuid())
 riderId String
 rider RiderProfile @relation(fields:[riderId],references:[id],onDelete:Cascade)
 status SubscriptionStatus @default(PENDING)
 startsAt DateTime?
 expiresAt DateTime?
 pricePaid Decimal? @db.Decimal(10,2)
 currency String @default("USD")
 activatedById String?
 activatedBy User? @relation("ActivatedBy",fields:[activatedById],references:[id])
 createdAt DateTime @default(now())
 planId String?
 plan SubscriptionPlan? @relation(fields:[planId],references:[id])
 paymentId String? @unique
 payment Payment? @relation(fields:[paymentId],references:[id])
}
model SubscriptionPlan {
 id String @id @default(cuid())
 code String @unique
 name String
 description String
 price Decimal @db.Decimal(10,2)
 currency String @default("NIO")
  durationDays Int
  dailyTripLimit Int @default(5)
 benefits Json
 isActive Boolean @default(true)
 displayOrder Int @default(0)
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 subscriptions RiderSubscription[]
 orders SubscriptionOrder[]
 @@index([isActive,displayOrder])
}
model PaymentMethodConfig {
 id String @id @default(cuid())
 code SubscriptionPaymentMethodCode @unique
 name String
 instructions String
 isActive Boolean @default(true)
 configuration Json?
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 payments Payment[]
}
model SubscriptionOrder {
 id String @id @default(cuid())
 riderId String
 rider RiderProfile @relation(fields:[riderId],references:[id],onDelete:Restrict)
 planId String
 plan SubscriptionPlan @relation(fields:[planId],references:[id],onDelete:Restrict)
 planNameSnapshot String
 priceSnapshot Decimal @db.Decimal(10,2)
 currencySnapshot String
 durationDaysSnapshot Int
 status SubscriptionOrderStatus @default(CREATED)
 expiresAt DateTime
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 payments Payment[]
 @@index([riderId,status])
 @@index([status,expiresAt])
}
model Payment {
 id String @id @default(cuid())
 orderId String @unique
 order SubscriptionOrder @relation(fields:[orderId],references:[id],onDelete:Restrict)
 methodId String
 method PaymentMethodConfig @relation(fields:[methodId],references:[id],onDelete:Restrict)
 amount Decimal @db.Decimal(10,2)
 currency String
 status SubscriptionPaymentStatus @default(PENDING_PAYMENT)
 externalReference String @unique
 customerReference String?
 proofReference String?
 metadata Json?
 submittedAt DateTime?
 reviewedAt DateTime?
 reviewedByAdminId String?
 rejectionReason String?
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 subscription RiderSubscription?
 @@index([status,createdAt])
 @@index([methodId,status])
}
model SubscriptionPayment {
 id String @id @default(cuid())
 riderId String
 rider RiderProfile @relation(fields:[riderId],references:[id],onDelete:Cascade)
 reference String @unique
 amount Decimal @db.Decimal(10,2)
 currency String @default("NIO")
 method PaymentMethod @default(POINT_EXPRESS)
 status PaymentStatus @default(PENDING)
 expiresAt DateTime
 confirmedAt DateTime?
 confirmedById String?
 createdAt DateTime @default(now())
 @@index([riderId,status])
 @@index([status,expiresAt])
}
model Trip {
 id String @id @default(cuid())
 clientId String
 client User @relation("ClientTrips",fields:[clientId],references:[id])
 riderId String?
 rider User? @relation("RiderTrips",fields:[riderId],references:[id])
 riderLat Float?
 riderLng Float?
 riderAccuracy Float?
 riderHeading Float?
 riderLocationUpdatedAt DateTime?
 status TripStatus @default(REQUESTED)
 originLat Float
 originLng Float
 originAddress String
 destinationLat Float
 destinationLng Float
 destinationAddress String
 distanceKm Float
 estimatedPrice Decimal @db.Decimal(10,2)
 proposedPrice Decimal? @db.Decimal(10,2)
 finalPrice Decimal? @db.Decimal(10,2)
 estimatedDurationMin Int
 serviceCode String @default("MOTO")
 expiresAt DateTime?
 currency String @default("USD")
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 histories TripStatusHistory[]
 rating Rating?
 offers TripOffer[]
 locations TripLocation[]
}
model TripLocation {
 id String @id @default(cuid())
 tripId String
 trip Trip @relation(fields:[tripId],references:[id],onDelete:Cascade)
 lat Float
 lng Float
 accuracy Float?
 heading Float?
 createdAt DateTime @default(now())
 @@index([tripId,createdAt])
}
model TripOffer {
 id String @id @default(cuid())
 tripId String
 trip Trip @relation(fields:[tripId],references:[id],onDelete:Cascade)
 riderId String
 rider User @relation(fields:[riderId],references:[id],onDelete:Cascade)
 amount Decimal @db.Decimal(10,2)
 currency String @default("NIO")
 status OfferStatus @default(PENDING)
 expiresAt DateTime
 createdAt DateTime @default(now())
 @@index([tripId,status])
 @@index([riderId,status])
}
model TripStatusHistory {
 id String @id @default(cuid())
 tripId String
 trip Trip @relation(fields:[tripId],references:[id],onDelete:Cascade)
 status TripStatus
 actorId String?
 createdAt DateTime @default(now())
 @@index([tripId,createdAt])
}
model Rating {
 id String @id @default(cuid())
 tripId String @unique
 trip Trip @relation(fields:[tripId],references:[id],onDelete:Cascade)
 authorId String
 author User @relation("RatingAuthor",fields:[authorId],references:[id])
 riderId String
 rider User @relation("RatingRider",fields:[riderId],references:[id])
 score Int
 comment String?
 createdAt DateTime @default(now())
}
model AuditLog {
 id String @id @default(cuid())
 actorId String?
 actor User? @relation("AuditActor",fields:[actorId],references:[id])
 action String
 entity String
 entityId String?
 metadata Json?
 createdAt DateTime @default(now())
 @@index([entity,entityId])
}
model RefreshToken {
 id String @id @default(cuid())
 tokenHash String @unique
 userId String
 user User @relation(fields:[userId],references:[id],onDelete:Cascade)
 expiresAt DateTime
 revokedAt DateTime?
 createdAt DateTime @default(now())
}
model SystemSetting {
 key String @id
 value String
 updatedAt DateTime @updatedAt
}
model SavedPlace {
 id String @id @default(cuid())
 userId String
 user User @relation(fields:[userId],references:[id],onDelete:Cascade)
 label String
 address String
 reference String?
 lat Float
 lng Float
 createdAt DateTime @default(now())
 @@unique([userId,label])
}
model Advertisement {
 id String @id @default(cuid())
 title String
 description String?
 imageUrl String?
 actionLabel String?
 actionUrl String?
 backgroundColor String @default("#f97316")
 textColor String @default("#ffffff")
 displayOrder Int @default(0)
 active Boolean @default(true)
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 @@index([active,displayOrder])
}
