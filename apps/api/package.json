{
  "name": "@motoya/api",
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc --noCheck",
    "start": "prisma migrate deploy && node dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "test": "jest --runInBand",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@motoya/shared": "workspace:*", "@prisma/client": "^6.4.1", "bcryptjs": "^2.4.3", "cors": "^2.8.5", "dotenv": "^16.4.7", "express": "^4.21.2", "express-rate-limit": "^7.5.0", "helmet": "^8.0.0", "jsonwebtoken": "^9.0.2", "pino": "^9.6.0", "socket.io": "^4.8.1", "zod": "^3.24.2"
  },
  "devDependencies": { "@types/bcryptjs": "^2.4.6", "@types/cors": "^2.8.17", "@types/express": "^5.0.0", "@types/jest": "^29.5.14", "@types/jsonwebtoken": "^9.0.9", "@types/supertest": "^6.0.2", "eslint": "^9.19.0", "jest": "^29.7.0", "prisma": "^6.4.1", "supertest": "^7.0.0", "ts-jest": "^29.2.5", "tsx": "^4.19.2", "typescript": "^5.7.3" },
  "prisma": { "seed": "tsx prisma/seed.ts" }
}
