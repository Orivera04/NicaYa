generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  RIDER
  ADMIN
}

enum RiderStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  PENDING
}

enum TripStatus {
  REQUESTED
  ACCEPTED
  EN_ROUTE
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         Role     @default(CLIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  riderProfile  RiderProfile?
  tripsAsClient Trip[]        @relation("ClientTrips")
  tripsAsRider  Trip[]        @relation("RiderTrips")

  @@index([email])
  @@index([role])
}

model RiderProfile {
  id                     String             @id @default(uuid())
  userId                 String             @unique
  status                 RiderStatus        @default(PENDING)
  avgRating              Float              @default(0)
  totalRides             Int                @default(0)
  documents              Json               @default("{}")
  subscriptionStatus     SubscriptionStatus @default(PENDING)
  subscriptionExpiresAt  DateTime?
  isAvailable            Boolean            @default(false)
  latitude               Float?
  longitude              Float?
  updatedAt              DateTime           @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([status])
  @@index([isAvailable])
  @@index([latitude, longitude])
}

model Subscription {
  id        String             @id @default(uuid())
  riderId   String
  startDate DateTime
  endDate   DateTime
  amount    Float
  currency  String             @default("NIO")
  status    SubscriptionStatus @default(ACTIVE)
  createdAt DateTime           @default(now())

  rider RiderProfile @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId])
  @@index([status])
}

model AppConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Trip {
  id               String     @id @default(uuid())
  clientId         String
  riderId          String?
  status           TripStatus @default(REQUESTED)
  originLat        Float
  originLng        Float
  originAddress    String
  destLat          Float
  destLng          Float
  destAddress      String
  suggestedPrice   Float
  negotiatedPrice  Float?
  finalPrice       Float?
  currency         String     @default("NIO")
  clientRating     Int?
  riderRating      Int?
  distance         Float?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  client User  @relation("ClientTrips", fields: [clientId], references: [id])
  rider  User? @relation("RiderTrips", fields: [riderId], references: [id])

  @@index([clientId])
  @@index([riderId])
  @@index([status])
  @@index([createdAt])
}
